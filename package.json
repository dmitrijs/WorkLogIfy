{
    "name": "work-log-ify",
    "version": "1.44.9",
    "description": "WorkLogIfy",
    "license": "MIT",
    "author": "Dmitrijs Sadovskis",
    "main": "dist-electron/main/index.js",
    "scripts": {
        "generate-database-types": "supabase gen types typescript --project-id yevrfoukghkxidpgpitx --schema public > app/database.types.ts",
        "dev": "vp dev",
        "compile": "tsc --noEmit && vp build",
        "build": "tsc --noEmit && vp build && electron-builder --windows --publish never",
        "build-mac": "tsc --noEmit && vp build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never && codesign --force --deep --sign \"WorkLogIfy Certificate\" \"release/mac-arm64/WorkLogIfy.app\"",
        "eslint": "npx eslint .",
        "standard-version": "npx standard-version",
        "standard-version-x.minor.z": "npx standard-version --release-as minor",
        "standard-version-x.y.patch": "npx standard-version --release-as patch",
        "standard-version-prerelease": "npx standard-version --prerelease local --release-as patch --skip.tag",
        "lint": "tslint app/**/*.ts{,x}",
        "postinstall": "electron-rebuild -f -w node-pty",
        "prepare": "vp config"
    },
    "dependencies": {
        "@radix-ui/react-dialog": "^1.1.17",
        "@radix-ui/react-popover": "^1.1.17",
        "@radix-ui/react-slot": "^1.3.0",
        "@supabase/supabase-js": "^2.78.0",
        "@tailwindcss/postcss": "^4.1.7",
        "@tailwindcss/vite": "^4.1.7",
        "@vitejs/plugin-react": "^5.2.0",
        "autoprefixer": "^10.4.21",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "electron-is-dev": "^2.0.0",
        "get-windows": "^9.3.0",
        "lodash": "^4.17.21",
        "lucide-react": "^0.511.0",
        "moment": "^2.24.0",
        "postcss": "^8.5.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "sass": "^1.26.3",
        "tailwind-merge": "^3.3.0",
        "tailwindcss": "^4.1.7",
        "tailwindcss-animate": "^1.0.7",
        "typesafe-ipc": "github:dmitrijs/typesafe-ipc#ea3facd456e7bfc947dd20addcb9cab45d4cd0ad",
        "vite-plugin-electron": "^1.0.4",
        "vite-plugin-electron-renderer": "^1.0.0",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@babel/types": "*",
        "@eslint/js": "^9.22.0",
        "@iconify-icon/react": "^3.0.0",
        "@types/lodash": "*",
        "@types/node": "^25.9.3",
        "@types/react": "^19.1.17",
        "@types/react-dom": "^19.1.11",
        "electron": "^42.4.0",
        "electron-builder": "^26.15.3",
        "esbuild": "^0.28.1",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "shadcn": "^2.5.0",
        "standard-version": "^9.3.2",
        "supabase": "^2.54.11",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.1",
        "vite-plus": "latest"
    },
    "overrides": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "packageManager": "npm@11.13.0",
    "standard-version": {
        "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n",
        "types": [
            {
                "type": "feat",
                "section": "Features"
            },
            {
                "type": "major",
                "section": "Features"
            },
            {
                "type": "minor",
                "section": "Improvements"
            },
            {
                "type": "ux",
                "section": "UI/UX"
            }
        ],
        "releaseCommitMessageFormat": "chore(release): v{{currentTag}}"
    },
    "__NOTES": [
        "electron 27+ has issues to re-draw UI elements on Windows! For example, calendar disappear until mouse moves over it. Workaround: app.disableHardwareAcceleration()",
        "electron-builder 25+ fails to build because of node-gyp error"
    ]
}
