{
  "compilerOptions": {
    "paths": {
      "@/*": ["./app/*"]
    },
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "target": "esnext",
    "jsx": "preserve",
    "sourceMap": true,
    // this enables stricter inference for data properties on `this`
    // "strict": true,
    // if using webpack 2+ or rollup, to leverage tree shaking:
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true
  },
  "include": ["app", "public"]
}
